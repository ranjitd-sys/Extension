{
  "manifest_version": 3,
  "name": "My First Extension",
  "version": "1.0",
  "description": "Basic Chrome Extension",
  
  "action": {
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],

  "permissions": ["storage", "activeTab"]
}